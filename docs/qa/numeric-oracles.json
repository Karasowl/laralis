    {
      "id": "num-001-acquisition-counts",
      "priority": "P0",
      "domain": "patients",
      "status": "covered",
      "businessDecision": "Medir captacion real por fuente y evitar decisiones de marketing basadas en pacientes mal atribuidos.",
      "formula": "patientGroups grouped by sourceKey, mapped to source display name",
      "assertions": [
        { "label": "patients total", "path": "oracles.patients.total", "expected": 30, "unit": "count" },
        { "label": "Meta Mayo patients", "path": "oracles.patients.bySource.Meta Mayo", "expected": 22, "unit": "count" },
        { "label": "Referidos patients", "path": "oracles.patients.bySource.Referidos", "expected": 7, "unit": "count" },
        { "label": "Organico patients", "path": "oracles.patients.bySource.Organico", "expected": 1, "unit": "count" }
      ],
      "layers": {
        "formula": ["apps/dental/tests/qa/qa-oracles.test.ts"],
        "api": [
          { "route": "GET /api/patients", "spec": "apps/dental/cypress/e2e/stage/02-qa-business-oracles.cy.ts" },
          { "route": "GET /api/reports/summary", "spec": "apps/dental/cypress/e2e/stage/19-reports-dashboard-oracles.cy.ts" }
