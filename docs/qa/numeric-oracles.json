          { "surface": "/ dashboard cards", "spec": "apps/dental/cypress/e2e/stage/19-reports-dashboard-oracles.cy.ts" }
        ],
        "export": [
          { "key": "patients", "spec": "apps/dental/cypress/e2e/stage/32-data-portability-security-snapshots.cy.ts" }
        ]
      }
    },
