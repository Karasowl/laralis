    "test:e2e:stage:visual-responsive": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_VIDEO=false cypress run --quiet --config numTestsKeptInMemory=0,screenshotOnRunFailure=false --spec \"cypress/e2e/stage/15-visual-responsive-coverage.cy.ts\"",
    "test:e2e:stage:full-lifecycle": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_SUPABASE_URL=https://kafbqdliromcveojtdar.supabase.co CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/16-full-lifecycle-user.cy.ts\"",
    "test:e2e:stage:crons": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_SUPABASE_URL=https://kafbqdliromcveojtdar.supabase.co CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/17-cron-jobs.cy.ts\"",
    "test:e2e:stage:lara": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_SUPABASE_URL=https://kafbqdliromcveojtdar.supabase.co CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/18-lara-ai-actions.cy.ts\"",
    "test:e2e:stage:reports": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/19-reports-dashboard-oracles.cy.ts\"",
