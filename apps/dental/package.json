{
  "name": "@laralis/dental",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "kill-node": "taskkill /F /IM node.exe 2>nul || echo No hay procesos Node activos",
    "kill-next": "node scripts/kill-old-next.js",
    "dev": "node scripts/kill-old-next.js && next dev",
    "dev:wsl": "node scripts/kill-old-next.js && cross-env PORT=3001 WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=1 NEXT_WEBPACK_USEPOLLING=1 next dev -H 127.0.0.1 -p 3000",
    "dev:wsl:clean": "node scripts/kill-old-next.js && rm -rf .next && cross-env WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=1 NEXT_WEBPACK_USEPOLLING=1 next dev",
    "dev:force": "npm run kill-node & next dev",
    "dev:clean": "npm run kill-next && next dev",
    "dev:safe": "node scripts/cleanup.js & npm run kill-node && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:unit": "vitest run lib/calc",
    "test:calc": "vitest run lib/calc --coverage.enabled=false",
    "test:integration": "vitest run tests/calc",
    "test:api": "vitest run tests/api",
    "test:multitenancy": "vitest run tests/api/multitenancy.test.ts",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:multitenancy": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/04-multiclinic-isolation.cy.ts\"",
    "test:e2e:auth": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/00-auth-and-shell.cy.ts\"",
    "test:e2e:patients": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/01-readonly-dental-flow.cy.ts\"",
    "test:e2e:supplies": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/03-crud-lifecycle.cy.ts\"",
    "test:e2e:services": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/03-crud-lifecycle.cy.ts\"",
