    "test:e2e:stage": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app cypress run --spec \"cypress/e2e/stage/**/*.cy.{js,ts}\"",
    "test:e2e:stage:open": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app cypress open --e2e",
    "test:e2e:stage:headed": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app cypress run --headed --browser electron --spec \"cypress/e2e/stage/**/*.cy.{js,ts}\"",
