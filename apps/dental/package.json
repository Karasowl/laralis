    "test:e2e:stage:lara-isolation": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/21-lara-dashboard-multiclinic-isolation.cy.ts\"",
    "test:e2e:stage:navigation": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/22-navigation-session-regression.cy.ts\"",
    "test:e2e:stage:chart-tooltips": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_VIDEO=false cypress run --browser chrome --headless --config numTestsKeptInMemory=0,screenshotOnRunFailure=false --spec \"cypress/e2e/stage/23-chart-tooltips-dark-mode.cy.js\"",
    "test:e2e:stage:visual-regression": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_VIDEO=false cypress run --browser electron --headless --config numTestsKeptInMemory=0,screenshotOnRunFailure=false --spec \"cypress/e2e/stage/24-visual-regression-baselines.cy.js\"",
    "test:e2e:stage:account-deletion": "cross-env CYPRESS_BASE_URL=https://laralis-monorepo-preview.vercel.app CYPRESS_SUPABASE_URL=https://kafbqdliromcveojtdar.supabase.co CYPRESS_VIDEO=false cypress run --spec \"cypress/e2e/stage/25-account-deletion-self-service.cy.ts\"",
    "test:all": "node test-runner.js all",
    "test:quick": "npm run test:unit && npm run test:integration",
    "test:full": "npm run test:unit && npm run test:integration && npm run test:api && npm run test:e2e",
    "dev:preview": "concurrently \"npm run dev\" \"echo 'Abre Browser Preview en VSCode con Ctrl+Shift+P'\"",
    "dev:mobile": "next dev -H 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "i18n:check": "node scripts/check-i18n.mjs",
    "qa:inventory": "node scripts/qa-inventory.mjs",
    "qa:inventory:strict": "node scripts/qa-inventory.mjs --strict",
    "qa:seed:plan": "node scripts/qa-stage-seed.mjs --dry-run",
    "qa:seed": "node scripts/qa-stage-seed.mjs --apply",
    "qa:seed:reset": "node scripts/qa-stage-seed.mjs --apply --reset-only",
    "qa:stage:assert": "node scripts/qa-stage-assert.mjs",
    "qa:oracles": "vitest run tests/qa --coverage.enabled=false",
    "qa:check": "npm run qa:inventory && npm run qa:seed:plan && npm run qa:oracles && npm run test:calc",
    "i18n:fill": "node scripts/fill-i18n-missing.mjs",
    "i18n:collect": "node scripts/collect-used-i18n.mjs",
    "i18n:scan": "node scripts/scan-i18n-usage.mjs",
    "i18n:lint": "node scripts/collect-used-i18n.mjs && node scripts/missing-used-i18n.mjs && node scripts/scan-i18n-usage.mjs",
    "i18n:fix-es": "node scripts/fix-es-encoding.mjs && node scripts/scan-i18n-usage.mjs",
    "refactor:metrics": "node scripts/refactor-metrics.mjs",
    "version:patch": "node ../../scripts/bump-version.js patch",
    "version:minor": "node ../../scripts/bump-version.js minor",
    "version:major": "node ../../scripts/bump-version.js major"
