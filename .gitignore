.gitignore
# Dependencies
node_modules/
apps/*/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js
apps/*/.next/
apps/*/out/
apps/*/build/
apps/*/dist/

# Vercel
apps/*/.vercel
.vercel

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
apps/*/.env
apps/*/.env.local
apps/*/.env.development.local
apps/*/.env.test.local
apps/*/.env.production.local
apps/*/cypress.env.json

# Testing
apps/*/coverage/
apps/*/.nyc_output

# Turbo
.turbo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Cursor IDE
.cursor/

# Logs
*.log
logs/
apps/*/logs/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# TypeScript
*.tsbuildinfo
apps/*/*.tsbuildinfo

# Temporary files
tmp/
temp/
tmp*.txt
tmp*.tsx
tmp*.json
_tmp*.txt
_tmp*.json
*.backup
*.deprecated
_match_laralis.txt

# Supabase local development
supabase/.temp
supabase/.env
supabase/.branches

# Build outputs and caches
*.cache
.parcel-cache

# Misc
*.tgz
*.tar.gz
.cache/
.eslintcache
Planes/

# Database
*.db
*.sqlite
*.sqlite3

# Excel temp files
~$*.xlsx
~$*.xls

# Windows reserved names
nul
null
con
prn
aux
com[1-9]
lpt[1-9]

.vercel
